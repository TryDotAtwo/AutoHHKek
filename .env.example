# Copy this file to `.env` in the repo root. `python main.py` loads it automatically.

OPENAI_API_KEY=
AUTOHHKEK_OPENAI_MODEL=gpt-5.4
AUTOHHKEK_OPENAI_BASE_URL=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=

# OpenRouter is OpenAI-compatible and uses its own API key.
OPENROUTER_API_KEY=
AUTOHHKEK_OPENROUTER_MODEL=openai/gpt-4o-mini
AUTOHHKEK_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AUTOHHKEK_OPENROUTER_REFERER=
AUTOHHKEK_OPENROUTER_TITLE=AutoHHKek

AUTOHHKEK_G4F_MODEL=gpt-4o-mini
AUTOHHKEK_G4F_PROVIDER=

AUTOHHKEK_PLAYWRIGHT_MCP_COMMAND=npx
AUTOHHKEK_PLAYWRIGHT_MCP_ARGS=-y @playwright/mcp@latest
